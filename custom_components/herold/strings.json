  "services": {
    "send": {
      "name": "Send notification",
      "description": "Sends a fire-and-forget notification through the Herold dispatcher (voice, push and Telegram).",
      "fields": {
        "message": {
          "name": "Message",
          "description": "The notification text."
        },
        "priority": {
          "name": "Priority",
          "description": "0 = internal, 1 = todo, 2 = normal, 3 = important, 4 = alarm."
        },
        "recipient": {
          "name": "Recipient",
          "description": "Person entity; defaults to the configured recipient."
        },
        "target_player": {
          "name": "Target player",
          "description": "Optional target that overrides room detection."
        },
        "title": {
          "name": "Title",
          "description": "Optional push notification title."
        },
        "tag": {
          "name": "Tag",
          "description": "Optional tag for deduplication (used from Phase 4)."
        },
        "ttl_minutes": {
          "name": "TTL (minutes)",
          "description": "Optional auto-expiry (used from a later phase)."
        },
        "callback_event": {
          "name": "Callback event",
          "description": "Legacy callback event id (only meaningful for queries)."
        }
      }
    },
    "query": {
      "name": "Ask a query",
      "description": "Sends a question and waits for an answer via satellite conversation, Telegram buttons or the acknowledge service.",
      "fields": {
        "question": {
          "name": "Question",
          "description": "The question text."
        },
        "mode": {
          "name": "Mode",
          "description": "yesno = yes/no buttons, open = free-text answer, choice = predefined options."
        },
        "choices": {
          "name": "Choices",
          "description": "Answer options (required for mode 'choice')."
        },
        "priority": {
          "name": "Priority",
          "description": "0 = internal, 1 = todo, 2 = normal, 3 = important, 4 = alarm."
        },
        "callback_event": {
          "name": "Callback event",
          "description": "Event id for the answer. Default AI_CONFIRM fires AI_YES/AI_NO (legacy compatible); a custom id XYZ fires XYZ_YES/XYZ_NO."
        },
        "timeout_minutes": {
          "name": "Timeout (minutes)",
          "description": "How long to wait for an answer before expiring."
        },
        "default_answer": {
          "name": "Default answer",
          "description": "Used automatically when the timeout is reached."
        },
        "recipient": {
          "name": "Recipient",
          "description": "Person entity; defaults to the configured recipient."
        },
        "target_player": {
          "name": "Target player",
          "description": "Optional target that overrides room detection."
        }
      }
    },
    "acknowledge": {
      "name": "Answer a query",
      "description": "Resolves a pending query with an answer.",
      "fields": {
        "id": {
          "name": "Query ID",
          "description": "The id of the pending query."
        },
        "answer": {
          "name": "Answer",
          "description": "For yesno: Ja/Nein; for choice: one of the choices; for open: any text."
        },
        "source": {
          "name": "Source",
          "description": "Where the answer came from (for the answered event)."
        }
      }
    },
    "cancel": {
      "name": "Cancel a query",
      "description": "Cancels a pending query without firing answer events.",
      "fields": {
        "id": {
          "name": "Query ID",
          "description": "The id of the pending query."
        },
        "reason": {
          "name": "Reason",
          "description": "Optional reason, only logged."
        }
      }
    }
